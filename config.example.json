{
  "global": {
    "zip_password": "global-secret",
    "retain_count": 5,
    "log_level": "info",
    "mysqldump_path": "mysqldump",
    "pg_dump_path": "pg_dump"
  },
  "source": [
    {
      "name": "nas",
      "url": "https://nas.example.com/dav",
      "username": "backup_user",
      "password": "backup_pass",
      "sub_dir": "backups"
    },
    {
      "name": "cloud",
      "url": "https://cloud.example.com/dav",
      "username": "cloud_user",
      "password": "cloud_pass",
      "proxy": "http://proxy.example.com:8080"
    }
  ],
  "backup": [
    {
      "source": "nas",
      "retain_count": 3,
      "sub_dir": "documents",
      "file": {
        "local_path": "D:\\Documents",
        "exclude": "node_modules target *.tmp Thumbs.db"
      }
    },
    {
      "source": "cloud",
      "sub_dir": "blog_db",
      "mysql": {
        "host": "localhost",
        "port": 3306,
        "username": "root",
        "password": "db_password",
        "database": "blog",
        "tables": "*"
      }
    },
    {
      "source": "nas",
      "sub_dir": "analytics_db",
      "pgsql": {
        "host": "localhost",
        "port": 5432,
        "username": "postgres",
        "password": "db_password",
        "database": "analytics",
        "tables": "*"
      }
    }
  ]
}
