{
  "global": {
    "zip_password": "global-secret",
    "retain_count": 5,
    "log_level": "info",
    "mysqldump_path": "mysqldump",
    "pg_dump_path": "pg_dump",
    "sqlite3_path": "sqlite3"
  },
  "source": [
    {
      "name": "nas",
      "url": "https://nas.example.com/dav",
      "username": "backup_user",
      "password": "backup_pass",
      "sub_dir": "backups"
    },
    {
      "name": "cloud",
      "url": "https://cloud.example.com/dav",
      "username": "cloud_user",
      "password": "cloud_pass",
      "proxy": "http://proxy.example.com:8080"
    }
  ],
  "backup": [
    {
      "source": "nas",
      "retain_count": 3,
      "sub_dir": "documents",
      "file": {
        "local_path": ["D:\\Documents", "D:\\Photos"],
        "exclude": "node_modules target *.tmp Thumbs.db"
      }
    },
    {
      "source": "cloud",
      "sub_dir": "dbs",
      "mysql": {
        "host": "localhost",
        "port": 3306,
        "username": "root",
        "password": "db_password",
        "database": ["blog.posts", "blog.comments", "analytics.*"]
      }
    },
    {
      "source": "nas",
      "sub_dir": "dbs",
      "pgsql": {
        "host": "localhost",
        "port": 5432,
        "username": "postgres",
        "password": "db_password",
        "database": ["sales.*", "inventory.products"]
      }
    },
    {
      "source": "cloud",
      "sub_dir": "sqlite",
      "sqlite": {
        "database": ["D:\\data\\app.db", "D:\\data\\cache.db"]
      }
    }
  ]
}
